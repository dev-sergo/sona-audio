# ── Mac: main API server ────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0

# Storage (Mac local)
DB_PATH=data/studio.db
AUDIO_PATH=data/audio

# GPU box model server address
MODEL_SERVER_URL=http://<gpu-box-ip>:8001

# LLM (llama-swap on GPU box)
LLM_URL=http://<gpu-box-ip>:8080
LLM_MODEL=qwen3-32k

# ── GPU box: model server ───────────────────────────────────
# (only needed in model_server/.env on the GPU box)
PORT=8001
HOST=0.0.0.0

WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

ACESTEP_MODEL_PATH=/home/serbio/Documents/ComfyUI/models/ace-step

# ── Telegram bot (Mac) ──────────────────────────────────────
TELEGRAM_TOKEN=your_token_here
API_URL=http://localhost:8000
