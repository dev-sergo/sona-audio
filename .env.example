# ── Mac: main API server ────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0

# Storage (Mac local)
DB_PATH=data/studio.db
AUDIO_PATH=data/audio

# GPU box model server address
MODEL_SERVER_URL=http://<gpu-box-ip>:8001

# ACE-Step API server on GPU box
ACESTEP_URL=http://<gpu-box-ip>:8002

# LLM (llama-swap — if running on Mac use host.docker.internal, if on GPU box use its IP)
LLM_URL=http://host.docker.internal:8080
LLM_MODEL=gemma-4-26b-a4b-it-mxfp4-moe-ctx-32k-q8-0-kv-t07

# ── GPU box: model server ───────────────────────────────────
# (only needed in model_server/.env on the GPU box)
PORT=8001
HOST=0.0.0.0

WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Absolute path to ACE-Step weights on the GPU box (no ~ expansion — use a full path)
ACESTEP_MODEL_PATH=<path-to-ace-step-models>

# ── Telegram bot (Mac) ──────────────────────────────────────
TELEGRAM_TOKEN=your_token_here
API_URL=http://localhost:8000
